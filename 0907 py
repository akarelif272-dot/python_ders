# Class

class stack:
    def __init__(self):
        #boş stack oluşturur
        self.elemanlar =[]

    def push(self, eleman):
        #stack2e eleman ekler
        self.elemanlar.append(eleman) 
    def pop(self):
        # tepedeki elemanı getirir
        self.elemanlar.pop()

  
    def peek(self):
        if self.bosmu():
            raise IndexError("yığın boş!")
        
        self.elemanlar[-1]

    def bosmu(self):
        return len(self.elemanlar) == 0
    

    def elemansayisi(self):
        return len(self.elemanlar)
    
    def __str__(self):
        return f"Yığın({self.elemanlar})"
    
    def yaz(self):
        print(self)

y = stack()

print(y.elemansayisi())

y.push(4)

y.yaz()



